# Arquivos desnecessários para build Docker
target/
*.md
*.bat
.git/
.gitignore
.vscode/
.idea/
*.iml

# IMPORTANTE: NÃO excluir .mvn/ e mvnw - são necessários para o build!

# Logs
*.log

# Arquivos temporários
*.tmp
*.temp

# Configurações locais
application-local.properties
application-ipv4.properties
application-direct-ipv6.properties

# Scripts de desenvolvimento (exceto mvnw)
run-*.bat
test-*.bat
verify-*.bat
start*.bat
debug*.bat
deploy*.bat
*.ps1

# Dockerfiles não usados
Dockerfile.bak
Dockerfile.root.bak
